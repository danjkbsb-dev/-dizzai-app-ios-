name: Build and Release

on:
  push:
    branches: [ main ]
  workflow_dispatch:

jobs:
  build:
    runs-on: ubuntu-latest
    env:
      NODE_OPTIONS: "--max-old-space-size=4096"
      FORCE_JAVASCRIPT_ACTIONS_TO_NODE24: true

    steps:
      - name: Checkout repository
        uses: actions/checkout@v5

      - name: Setup Node
        uses: actions/setup-node@v5
        with:
          node-version: 24

      - name: Remove pnpm lock file
        run: rm -f pnpm-lock.yaml

      - name: Install dependencies with npm
        run: npm install

      - name: Build Web App
        run: npm run build

      - name: Create GitHub Release
        uses: softprops/action-gh-release@v2
        with:
          tag_name: v1.0.0-${{ github.run_number }}
          name: DizzAí v1.0.0 Build ${{ github.run_number }}
          body: |
            🚀 DizzAí - App Inovador de Informação em Tempo Real
            
            ## ✨ Funcionalidades:
            - 🗺️ Mapa interativo com Google Maps
            - 📊 Status em tempo real (lotação, vibe, preço, música, atendimento)
            - 📢 Sistema de reports da comunidade
            - 📰 Feed de atividades em tempo real
            - 🚨 Alertas inteligentes
            - ❤️ Favoritos e notificações
            - 📝 Histórico pessoal
            - 🏆 Ranking de usuários
            - 💬 Chat por lugar
            - 📱 Compartilhamento social
            
            ## 🎯 Objetivo:
            Saiba em tempo real como está cada lugar do DF:
            - Como está o lugar agora (cheio, vazio, bom, ruim)
            - Quantas pessoas estão lá
            - Qual é a vibe/clima do lugar
            - Qualidade do atendimento
            - Preços (caro, normal, barato)
            - Tipo de música
            - Localização exata
            - Horário de funcionamento
            - Alertas (fila, problema, evento especial)
            
            ## 🔗 Links:
            - [Acessar DizzAí](https://dizzai.manus.space)
            - [Documentação](https://github.com/danjkbsb-dev/dizzai/blob/main/CODIGO_COMPLETO.md)
            - [Repositório](https://github.com/danjkbsb-dev/dizzai)
            
            ## 📊 Build Info:
            - **Build Number:** ${{ github.run_number }}
            - **Commit:** ${{ github.sha }}
            - **Branch:** ${{ github.ref }}
            - **Author:** ${{ github.actor }}
            
            ## 🛠️ Stack Técnico:
            - **Frontend:** React 19, Tailwind CSS 4, Google Maps
            - **Backend:** Express, tRPC, WebSocket
            - **Database:** MySQL/TiDB, Drizzle ORM
            - **Auth:** Manus OAuth
            - **Deployment:** Manus Platform
            
            ## 🎨 Design:
            - **Cores:** Verde Vibrante (#00D084), Azul (#0066FF), Laranja (#FF6B35)
            - **Tipografia:** Poppins (títulos), Inter (corpo)
            - **Tema:** Dark/Moderno com acentos neon
            
            ---
            
            **DizzAí! - Saiba como está o lugar AGORA! 🚀**
            
            Obrigado por usar DizzAí! 💚
          draft: false
          prerelease: false
